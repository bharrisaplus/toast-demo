html::before
  content: 'CodePen ♥ The Web'
  position: fixed
  inset: 0
  z-index: -1
  margin: auto
  width: fit-content
  height: fit-content
  font-family: monospace
  opacity: 0.6
  background: rebeccapurple
  color: white
  padding: 4px 8px
  border-radius: 4px

html
  height: 100%
  width: 100%

body
  height: calc(100% - 16px)
  width: calc(100% - 16px)
  margin: 8px

#shell
  height: 100%
  width: 100%

  & button#lever
    font-size: 13px
    max-height: 24px
    width: fit-content

footer
  display: none

#toaster
  height: 90%
  width: 250px
  position: fixed
  right: 18px
  bottom: 5%
  z-index: 2
  background: blue
  pointer-events: none
  anchor-name: --toast-anchor

  & .toast
    position-anchor: --toast-anchor
    position: relative
    top: 36px
    left: calc(100% - 232px)
    margin: 0
    pointer-events: auto

    &::backdrop
      display: none

    &:nth-child(2)
      top: 136px
      border-color: red
    &:nth-child(3)
      top: 236px
      border-color: green

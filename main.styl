html::before
  content: 'CodePen ♥ The Web'
  position: fixed
  inset: 0
  z-index: -1
  margin: auto
  width: fit-content
  height: fit-content
  font-family: monospace
  opacity: 0.6
  background: rebeccapurple
  color: white
  padding: 4px 8px
  border-radius: 4px

html
  height: 100%
  width: 100%

body
  height: calc(100% - 16px)
  width: calc(100% - 16px)
  margin: 8px

#shell
  height: 100%
  width: 100%

  & button#lever
    font-size: 13px
    max-height: 24px
    width: fit-content

footer
  display: none

#toaster
  display: flex
  height: 100%
  width: 250px
  position: relative
  left: calc(100% - 250px)
  bottom: 100%
  z-index: 10
  flex-flow: column nowrap
  gap: 18px 0
  background: transparent
  anchor-name: --toast-anchor

  & .toast
    position: absolute
    margin: 0
    top: 16px
    left: calc(100% - 250px)
    position-anchor: --toast-anchor

    &::backdrop
      display: none

    &:nth-child(2)
      top: 116px
      border-color: red
    &:nth-child(3)
      top: 216px
      border-color: green
